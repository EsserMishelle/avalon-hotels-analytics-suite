            <column-instance column='[Calculation_0812868224552965]' derivation='Sum' name='[sum:Calculation_0812868224552965:qk]' pivot='key' type='quantitative' />
            <column caption='Total Nights' datatype='integer' name='[total_nights]' role='measure' type='ordinal' />
          </datasource-dependencies>
          <manual-sort column='[federated.1w4my0d11xnlwb1gzdsi10l8qcvk].[none:customer_type:nk]' direction='ASC'>
