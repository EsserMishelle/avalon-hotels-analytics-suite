    <worksheet name='Day of Week vs Cancellation'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontsize='10'>Cancellation Rate by Day of Week</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Cancellation rates increase toward the weekend, peaking on Friday and Saturday</run>
            <run fontname='Benton Sans Book'>.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Arrival_weekday_shorten' datatype='string' name='[Calculation_0431337260036096]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_weekday], 3)' />
            </column>
            <column caption='Cancel_Diff' datatype='real' name='[Calculation_0812868167503874]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([is_canceled])- AVG({ FIXED : AVG([is_canceled])})' />
            </column>
            <column caption='Weekly_Avg_Cancel_Diff' datatype='string' name='[Calculation_0812868168155139]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0812868167503874] &gt;= 0 THEN &apos;Above Avg&apos;&#13;&#10;ELSE &apos;Below Avg&apos;&#13;&#10;END' />
            </column>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
            </column>
            <column caption='Arrival_month_shorten' datatype='string' name='[Calculation_1198796274950151]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_date_month], 3)' />
            </column>
            <column caption='Arrival Date' datatype='date' name='[arrival_date]' role='dimension' type='ordinal' />
            <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;April&quot;' value='Apr' />
                <alias key='&quot;August&quot;' value='Aug' />
                <alias key='&quot;December&quot;' value='Dec' />
                <alias key='&quot;February&quot;' value='Feb' />
                <alias key='&quot;January&quot;' value='Jan' />
                <alias key='&quot;July&quot;' value='Jul' />
                <alias key='&quot;June&quot;' value='Jun' />
                <alias key='&quot;March&quot;' value='Mar' />
                <alias key='&quot;November&quot;' value='Nov' />
                <alias key='&quot;October&quot;' value='Oct' />
                <alias key='&quot;September&quot;' value='Sept' />
              </aliases>
            </column>
            <column caption='Arrival Weekday' datatype='string' name='[arrival_weekday]' role='dimension' type='nominal' />
            <column caption='Deposit Type' datatype='string' name='[deposit_type]' role='dimension' type='nominal'>
              <aliases>
