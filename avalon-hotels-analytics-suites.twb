    <worksheet name='ADR by Weekday'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Book' fontsize='10'>ADR Rate by Day of Week</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>ADR is highest on Friday and Saturday and lowest on Tuesday and Wednesday, suggesting stronger pricing power near the weekend.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Arrival_weekday_shorten' datatype='string' name='[Calculation_0431337260036096]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_weekday], 3)' />
            </column>
            <column caption='ADR_Diff' datatype='real' name='[Calculation_0812868136321024]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([adr])- AVG({ FIXED : AVG([adr]) })' />
            </column>
            <column caption='Weekly_Avg_ADR_Diff' datatype='string' name='[Calculation_0812868166549505]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0812868136321024] &gt;= 0 THEN &apos;Above Avg&apos;&#13;&#10;ELSE &apos;Below Avg&apos;&#13;&#10;END' />
            </column>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
            </column>
            <column caption='Arrival_month_shorten' datatype='string' name='[Calculation_1198796274950151]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_date_month], 3)' />
            </column>
