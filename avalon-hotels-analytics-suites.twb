    <worksheet name='Lead Time vs ADR'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontsize='9'>ADR by Booking Lead Time </run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>City hotels consistently charge ADR than resort hotels across all booking lead times, indicating stronger pricing power in urban markets. Customers who book further in advance tend to pay higher rates, while last-minute bookings are associated with lower ADR.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
            </column>
            <column caption='Arrival_month_shorten' datatype='string' name='[Calculation_1198796274950151]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_date_month], 3)' />
            </column>
            <column caption='Adr' datatype='real' name='[adr]' role='measure' type='quantitative' />
            <column caption='Arrival Date' datatype='date' name='[arrival_date]' role='dimension' type='ordinal' />
            <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;April&quot;' value='Apr' />
                <alias key='&quot;August&quot;' value='Aug' />
                <alias key='&quot;December&quot;' value='Dec' />
                <alias key='&quot;February&quot;' value='Feb' />
                <alias key='&quot;January&quot;' value='Jan' />
                <alias key='&quot;July&quot;' value='Jul' />
                <alias key='&quot;June&quot;' value='Jun' />
                <alias key='&quot;March&quot;' value='Mar' />
                <alias key='&quot;November&quot;' value='Nov' />
                <alias key='&quot;October&quot;' value='Oct' />
                <alias key='&quot;September&quot;' value='Sept' />
              </aliases>
            </column>
            <column-instance column='[adr]' derivation='Avg' name='[avg:adr:qk]' pivot='key' type='quantitative' />
            <column caption='Deposit Type' datatype='string' name='[deposit_type]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;No Deposit&quot;' value='No  Dep' />
                <alias key='&quot;Refundable&quot;' value='Ref' />
              </aliases>
            </column>
            <column caption='Hotel' datatype='string' name='[hotel]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;City Hotel&quot;' value='City' />
                <alias key='&quot;Resort Hotel&quot;' value='Resort' />
              </aliases>
            </column>
            <column caption='Lead Time Group' datatype='string' name='[lead_time_group]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;last_min&quot;' value='Last Min' />
                <alias key='&quot;long&quot;' value='Long' />
                <alias key='&quot;medium&quot;' value='Med' />
                <alias key='&quot;short&quot;' value='Short' />
                <alias key='&quot;very_long&quot;' value='Very Long' />
