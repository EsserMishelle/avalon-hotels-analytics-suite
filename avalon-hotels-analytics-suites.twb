              <groupfilter direction='DESC' expression='SUM([Calculation_0812868224552965])' function='order' user:ui-marker='order'>
                <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
