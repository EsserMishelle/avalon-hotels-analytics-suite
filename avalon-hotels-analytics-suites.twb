          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
            </column>
            <column caption='Guest_Group' datatype='string' name='[Calculation_1198796272971782]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [adults] + [children]+ [babies] = 1 THEN &apos;Solo&apos;&#13;&#10;ELSEIF ([adults] = 2 and ([children]+ [babies] =0)) THEN &apos;Couple&apos;&#13;&#10;ELSEIF [adults] + [children]+ [babies] &lt;= 4 THEN &apos;Family&apos;&#13;&#10;ELSE &apos;Large Group&apos;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;Family&quot;' value='Fam.' />
                <alias key='&quot;Large Group&quot;' value='Lrge Grp' />
              </aliases>
            </column>
