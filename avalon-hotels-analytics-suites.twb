    <worksheet name='Deposit Type vs Cancellation2'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontsize='9'>Cancellation by Deposit Type</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Cancellation Rate' datatype='real' name='[Calculation_0393128564252672]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum([is_canceled])/COUNT([is_canceled])' />
            </column>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
            </column>
            <column caption='Arrival_month_shorten' datatype='string' name='[Calculation_1198796274950151]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_date_month], 3)' />
            </column>
            <column caption='Canceled Result Flag' datatype='string' name='[Calculation_5830710201069568]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([is_canceled]) &gt; WINDOW_AVG(AVG([is_canceled]))&#13;&#10;THEN &apos;Above Benchmark&apos;&#13;&#10;ELSE &apos;Below Benchmark&apos;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Arrival Date' datatype='date' name='[arrival_date]' role='dimension' type='ordinal' />
            <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal'>
              <aliases>
