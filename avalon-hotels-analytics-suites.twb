            <column-instance column='[__tableau_internal_object_id__].[clean_hotels.csv_06448C6BB9BA48589074A8BC218F712A]' derivation='Count' name='[__tableau_internal_object_id__].[cnt:clean_hotels.csv_06448C6BB9BA48589074A8BC218F712A:qk]' pivot='key' type='quantitative' />
            <column caption='Adr' datatype='real' name='[adr]' role='measure' type='quantitative' />
            <column caption='Adults' datatype='integer' name='[adults]' role='measure' type='quantitative' />
            <column caption='Arrival Date' datatype='date' name='[arrival_date]' role='dimension' type='ordinal' />
            <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal'>
