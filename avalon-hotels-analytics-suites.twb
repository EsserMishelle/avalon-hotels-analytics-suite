  <worksheets>
    <worksheet name='ADR Distribution by Hotel'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='10'>ADR Distribution by Hotel</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Most bookings cluster between $80–$120, with city hotels concentrated in mid-range pricing while resort hotels extend into higher price ranges.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
