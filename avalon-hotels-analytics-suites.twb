    <worksheet name='Guest Group size vs ADR'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='10'>ADR by Group Size</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
