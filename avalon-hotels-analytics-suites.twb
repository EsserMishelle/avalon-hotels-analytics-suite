    <worksheet name='Total Stay vs Cancellation'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontsize='9'>Stay Length Cancellation</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>Short stays drive volume, but long stays carry higher cancellation risk</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Total_stay_bins' datatype='string' name='[Calculation_0812868189495300]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [total_nights] &lt;= 2 THEN &apos;1-2 nights&apos;&#13;&#10;ELSEIF [total_nights] &lt;= 5 THEN &apos;3-5 nights&apos;&#13;&#10;ELSEIF [total_nights] &lt;= 10 THEN &apos;6-10 nights&apos;&#13;&#10;ELSEIF [total_nights] &gt; 10 THEN &apos;10+ nights&apos;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;1-2 nights&quot;' value='1-2    nights' />
                <alias key='&quot;10+ nights&quot;' value='10+    nights' />
                <alias key='&quot;3-5 nights&quot;' value='3-5    nights' />
                <alias key='&quot;6-10 nights&quot;' value='6-10    nights' />
              </aliases>
            </column>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
            </column>
            <column caption='Arrival_month_shorten' datatype='string' name='[Calculation_1198796274950151]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_date_month], 3)' />
            </column>
            <column caption='Arrival Date' datatype='date' name='[arrival_date]' role='dimension' type='ordinal' />
            <column caption='Arrival Date Month' datatype='string' name='[arrival_date_month]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;April&quot;' value='Apr' />
                <alias key='&quot;August&quot;' value='Aug' />
                <alias key='&quot;December&quot;' value='Dec' />
                <alias key='&quot;February&quot;' value='Feb' />
                <alias key='&quot;January&quot;' value='Jan' />
                <alias key='&quot;July&quot;' value='Jul' />
                <alias key='&quot;June&quot;' value='Jun' />
                <alias key='&quot;March&quot;' value='Mar' />
                <alias key='&quot;November&quot;' value='Nov' />
                <alias key='&quot;October&quot;' value='Oct' />
                <alias key='&quot;September&quot;' value='Sept' />
              </aliases>
            </column>
            <column-instance column='[is_canceled]' derivation='Avg' name='[avg:is_canceled:qk]' pivot='key' type='quantitative' />
            <column-instance column='[is_canceled]' derivation='Count' name='[cnt:is_canceled:qk]' pivot='key' type='quantitative' />
            <column caption='Deposit Type' datatype='string' name='[deposit_type]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;No Deposit&quot;' value='No  Dep' />
                <alias key='&quot;Refundable&quot;' value='Ref' />
              </aliases>
            </column>
            <column caption='Hotel' datatype='string' name='[hotel]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;City Hotel&quot;' value='City' />
                <alias key='&quot;Resort Hotel&quot;' value='Resort' />
              </aliases>
            </column>
            <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
            <column caption='Market Segment' datatype='string' name='[market_segment]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Aviation&quot;' value='Aviat.' />
                <alias key='&quot;Complementary&quot;' value='Compl.' />
                <alias key='&quot;Corporate&quot;' value='Corp.' />
                <alias key='&quot;Online TA&quot;' value='Online' />
              </aliases>
