    <worksheet name='Rev vs Cancellation by Segment'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='11'>Revenue vs Cancellation Risk by Market Segment</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Online TA generates high revenue but falls into the high cancellation quadrant, indicating revenue leakage risk.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Arrival_weekday_shorten' datatype='string' name='[Calculation_0431337260036096]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([arrival_weekday], 3)' />
            </column>
            <column caption='Revenue' datatype='real' name='[Calculation_0812868224552965]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [is_canceled] = 0 THEN &#13;&#10;[adr] * [total_nights]&#13;&#10;END' />
            </column>
            <column caption='Quadrant_Rev' datatype='string' name='[Calculation_0812868392820746]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([Calculation_0812868224552965]) &gt;= WINDOW_AVG(SUM([Calculation_0812868224552965])) AND AVG([is_canceled]) &gt;= WINDOW_AVG(AVG([is_canceled])) THEN &quot;High Value / High Risk&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Calculation_0812868224552965]) &gt;= WINDOW_AVG(SUM([Calculation_0812868224552965])) AND AVG([is_canceled]) &lt; WINDOW_AVG(AVG([is_canceled])) THEN &quot;High Value / Low Risk&quot;&#13;&#10;&#13;&#10;ELSEIF SUM([Calculation_0812868224552965]) &lt; WINDOW_AVG(SUM([Calculation_0812868224552965])) AND AVG([is_canceled]) &gt;= WINDOW_AVG(AVG([is_canceled])) THEN &quot;Low Value / High Risk&quot;&#13;&#10;&#13;&#10;ELSE &quot;Low Value / Low Risk&quot;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
            </column>
            <column caption='Adr' datatype='real' name='[adr]' role='measure' type='quantitative' />
            <column caption='Arrival Date' datatype='date' name='[arrival_date]' role='dimension' type='ordinal' />
            <column caption='Arrival Weekday' datatype='string' name='[arrival_weekday]' role='dimension' type='nominal' />
            <column-instance column='[is_canceled]' derivation='Avg' name='[avg:is_canceled:qk]' pivot='key' type='quantitative' />
            <column-instance column='[market_segment]' derivation='Count' name='[cnt:market_segment:qk]' pivot='key' type='quantitative' />
            <column caption='Customer Type' datatype='string' name='[customer_type]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Transient&quot;' value='Tran-   sient' />
                <alias key='&quot;Transient-Party&quot;' value='Tran-  Party' />
              </aliases>
            </column>
            <column caption='Deposit Type' datatype='string' name='[deposit_type]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;No Deposit&quot;' value='No  Dep' />
                <alias key='&quot;Refundable&quot;' value='Ref' />
              </aliases>
            </column>
            <column caption='Hotel' datatype='string' name='[hotel]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;City Hotel&quot;' value='City' />
                <alias key='&quot;Resort Hotel&quot;' value='Resort' />
              </aliases>
            </column>
            <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
            <column caption='Market Segment' datatype='string' name='[market_segment]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Corporate&quot;' value='Corp.' />
              </aliases>
            </column>
            <column-instance column='[Calculation_0431337260036096]' derivation='None' name='[none:Calculation_0431337260036096:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1198796077133824]' derivation='None' name='[none:Calculation_1198796077133824:nk]' pivot='key' type='nominal' />
            <column-instance column='[customer_type]' derivation='None' name='[none:customer_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[deposit_type]' derivation='None' name='[none:deposit_type:nk]' pivot='key' type='nominal' />
