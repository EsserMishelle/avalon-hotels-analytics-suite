            <column-instance column='[Calculation_1198796077133824]' derivation='None' name='[none:Calculation_1198796077133824:nk]' pivot='key' type='nominal' />
            <column-instance column='[customer_type]' derivation='None' name='[none:customer_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[deposit_type]' derivation='None' name='[none:deposit_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[hotel]' derivation='None' name='[none:hotel:nk]' pivot='key' type='nominal' />
            <column-instance column='[market_segment]' derivation='None' name='[none:market_segment:nk]' pivot='key' type='nominal' />
            <column caption='Total Nights' datatype='integer' name='[total_nights]' role='measure' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1w4my0d11xnlwb1gzdsi10l8qcvk].[Action (Market Segment)]'>
            <groupfilter function='level-members' level='[market_segment]' user:ui-action-filter='[Action1_C52164C56215423184E2C7B6C8E12F18]' user:ui-enumeration='all' user:ui-marker='enumerate' />
