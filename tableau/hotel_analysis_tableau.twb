              <calculation class='tableau' formula='LEFT([arrival_weekday], 3)' />
            </column>
            <column caption='Total_stay_bins' datatype='string' name='[Calculation_0812868189495300]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [total_nights] &lt;= 2 THEN &apos;1-2 nights&apos;&#13;&#10;ELSEIF [total_nights] &lt;= 5 THEN &apos;3-5 nights&apos;&#13;&#10;ELSEIF [total_nights] &lt;= 10 THEN &apos;6-10 nights&apos;&#13;&#10;ELSEIF [total_nights] &gt; 10 THEN &apos;10+ nights&apos;&#13;&#10;END' />
              <aliases>
                <alias key='&quot;1-2 nights&quot;' value='1-2    nights' />
                <alias key='&quot;10+ nights&quot;' value='10+    nights' />
                <alias key='&quot;3-5 nights&quot;' value='3-5    nights' />
                <alias key='&quot;6-10 nights&quot;' value='6-10    nights' />
              </aliases>
            </column>
            <column caption='Revenue' datatype='real' name='[Calculation_0812868224552965]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [is_canceled] = 0 THEN &#13;&#10;[adr] * [total_nights]&#13;&#10;END' />
            </column>
            <column caption='Weekday' datatype='string' name='[Calculation_1198796077133824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [arrival_date])' />
