            <column-instance column='[market_segment]' derivation='None' name='[none:market_segment:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0812868224552965]' derivation='Sum' name='[sum:Calculation_0812868224552965:qk]' pivot='key' type='quantitative' />
            <column caption='Total Nights' datatype='integer' name='[total_nights]' role='measure' type='ordinal' />
            <column-instance column='[Calculation_0812868392820746]' derivation='User' name='[usr:Calculation_0812868392820746:nk:3]' pivot='key' type='nominal'>
              <table-calc ordering-field='[federated.1w4my0d11xnlwb1gzdsi10l8qcvk].[market_segment]' ordering-type='Field' />
